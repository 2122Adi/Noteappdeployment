class IconButton(tk.Button):
    def __init__(self, parent, text, command=None, style="primary", **kw):
        styles = {
            "primary":  {"bg": C["accent"],   "fg": C["white"],  "abg": "#3A7AE8"},
            "success":  {"bg": C["success"],  "fg": C["white"],  "abg": "#22B86A"},
            "danger":   {"bg": C["danger"],   "fg": C["white"],  "abg": "#E04A4A"},
            "ghost":    {"bg": C["surface2"], "fg": C["text2"],  "abg": C["border"]},
            "gold":     {"bg": C["gold"],     "fg": C["bg"],     "abg": "#DDB52E"},
        }
        s = styles.get(style, styles["primary"])
        super().__init__(
            parent, text=text, command=command,
            font=FONT_BUTTON,
            bg=s["bg"], fg=s["fg"],
            activebackground=s["abg"], activeforeground=s["fg"],
            relief="flat", bd=0, cursor="hand2",
            padx=14, pady=7, **kw
        )
        self._abg = s["abg"]
        self._bg  = s["bg"]
        self.bind("<Enter>", lambda e: self.config(bg=self._abg))
        self.bind("<Leave>", lambda e: self.config(bg=self._bg))

class StrengthBar(tk.Frame):
    def __init__(self, parent, **kw):
        super().__init__(parent, bg=C["surface"], **kw)
        self._bars = []
        for i in range(5):
            b = tk.Frame(self, width=28, height=6, bg=C["border"])
            b.pack(side="left", padx=2)
            b.pack_propagate(False)
            self._bars.append(b)
        self._lbl = tk.Label(self, text="", font=FONT_SMALL,
                             fg=C["text2"], bg=C["surface"])
        self._lbl.pack(side="left", padx=6)

    def update_strength(self, pwd: str):
        score = 0
        if len(pwd) >= 8:   score += 1
        if len(pwd) >= 14:  score += 1
        if re.search(r"[A-Z]", pwd): score += 1
        if re.search(r"\d", pwd):    score += 1
        if re.search(r"[^A-Za-z0-9]", pwd): score += 1
        colours = [C["danger"], C["danger"], C["warning"], C["warning"], C["success"]]
        labels  = ["", "Very Weak", "Weak", "Fair", "Strong", "Very Strong"]
        for i, b in enumerate(self._bars):
            b.config(bg=colours[score-1] if score > 0 and i < score else C["border"])
        self._lbl.config(text=labels[score] if score else "",
                         fg=colours[score-1] if score else C["text2"])


