class MasterScreen(tk.Toplevel):
    def __init__(self, vault: Vault, on_success, mode="unlock"):
        super().__init__()
        self.vault      = vault
        self.on_success = on_success
        self.mode       = mode
        self.title(APP_NAME)
        self.resizable(False, False)
        self.configure(bg=C["bg"])
        h = 620 if mode == "setup" else 480
        self._center(460, h)
        try:
            import base64 as _b64, tempfile as _tmp, os as _os2
            _ico_path = _os2.path.join(_tmp.gettempdir(), "enix_app.ico")
            if _os2.path.exists(_ico_path):
                self.iconbitmap(default=_ico_path)
            else:
                _ico_data = _b64.b64decode(_ICO_B64)
                with open(_ico_path, "wb") as _f: _f.write(_ico_data)
                self.iconbitmap(default=_ico_path)
        except Exception:
            pass
        self.protocol("WM_DELETE_WINDOW", self.destroy)
        self._build()
        self.grab_set()

    def _center(self, w, h):
        sw = self.winfo_screenwidth()
        sh = self.winfo_screenheight()
        self.geometry(f"{w}x{h}+{(sw-w)//2}+{(sh-h)//2}")

    def _build(self):
        # gradient header
        hdr = tk.Frame(self, bg=C["surface"], height=180)
        hdr.pack(fill="x")
        hdr.pack_propagate(False)

        # logo area
        logo_f = tk.Frame(hdr, bg=C["surface"])
        logo_f.place(relx=0.5, rely=0.5, anchor="center")
        try:
            import base64 as _b64
            from PIL import Image as _Img, ImageTk as _ITk
            import io as _io
            _img = _Img.open(_io.BytesIO(_b64.b64decode(_LOGO_B64)))
            self._logo_img = _ITk.PhotoImage(_img)
            tk.Label(logo_f, image=self._logo_img, bg=C["surface"]).pack(pady=(0,6))
        except Exception:
            tk.Label(logo_f, text="🔐", font=("Segoe UI", 36), bg=C["surface"]).pack()
            tk.Label(logo_f, text="ENIX", font=("Segoe UI", 20, "bold"),
                     fg=C["accent"], bg=C["surface"]).pack()
        tk.Label(logo_f, text="Password Manager", font=("Segoe UI", 10),
                 fg=C["text2"], bg=C["surface"]).pack()

        body = tk.Frame(self, bg=C["bg"])
        body.pack(fill="both", expand=True, padx=40, pady=20)

        title = "Create Master Password" if self.mode == "setup" else "Unlock Your Vault"
        tk.Label(body, text=title, font=FONT_HEAD,
                 fg=C["text"], bg=C["bg"]).pack(pady=(0, 4))

        hint_text = ("Choose a strong master password.\nThis encrypts your entire vault."
                     if self.mode == "setup" else
                     "Enter your master password to access the vault.")
        tk.Label(body, text=hint_text, font=FONT_SMALL,
                 fg=C["text2"], bg=C["bg"], justify="center").pack(pady=(0, 18))

        # password field
        pf = tk.Frame(body, bg=C["bg"])
        pf.pack(fill="x", pady=4)
        tk.Label(pf, text="Master Password", font=FONT_LABEL,
                 fg=C["text2"], bg=C["bg"], anchor="w").pack(fill="x")
        ef = tk.Frame(pf, bg=C["surface2"], highlightthickness=1,
                      highlightbackground=C["border"], highlightcolor=C["accent"])
        ef.pack(fill="x", pady=4)
        self.pwd_var = tk.StringVar()
        self.pwd_entry = tk.Entry(ef, show="•", font=FONT_MONO, width=28,
                                  bg=C["surface2"], fg=C["text"],
                                  insertbackground=C["accent"],
                                  relief="flat", bd=8,
                                  textvariable=self.pwd_var)
        self.pwd_entry.pack(side="left", fill="x", expand=True)
        self._show = False
        eye = tk.Button(ef, text="👁", font=("Segoe UI", 10), bg=C["surface2"],
                        fg=C["text2"], relief="flat", bd=0, cursor="hand2",
                        command=self._toggle_show)
        eye.pack(side="right", padx=6)

        if self.mode == "setup":
            self.pwd_var.trace_add("write", self._on_pwd_change)
            self.strength = StrengthBar(body)
            self.strength.pack(pady=(0, 8))

            cf = tk.Frame(body, bg=C["bg"])
            cf.pack(fill="x", pady=4)
            tk.Label(cf, text="Confirm Password", font=FONT_LABEL,
                     fg=C["text2"], bg=C["bg"], anchor="w").pack(fill="x")
            cef = tk.Frame(cf, bg=C["surface2"], highlightthickness=1,
                           highlightbackground=C["border"], highlightcolor=C["accent"])
            cef.pack(fill="x", pady=4)
            self.confirm_var = tk.StringVar()
            tk.Entry(cef, show="•", font=FONT_MONO, width=28,
                     bg=C["surface2"], fg=C["text"],
                     insertbackground=C["accent"],
                     relief="flat", bd=8,
                     textvariable=self.confirm_var).pack(fill="x")

        self.status = tk.Label(body, text="", font=FONT_SMALL,
                               fg=C["danger"], bg=C["bg"])
        self.status.pack(pady=4)

        btn_text = "Create Vault" if self.mode == "setup" else "Unlock  →"
        IconButton(body, btn_text, command=self._submit,
                   style="primary").pack(fill="x", pady=8, ipady=4)

        self.pwd_entry.bind("<Return>", lambda e: self._submit())
        self.pwd_entry.focus()

    def _toggle_show(self):
        self._show = not self._show
        self.pwd_entry.config(show="" if self._show else "•")

    def _on_pwd_change(self, *_):
        self.strength.update_strength(self.pwd_var.get())

    def _submit(self):
        pwd = self.pwd_var.get()
        if not pwd:
            self.status.config(text="Password cannot be empty."); return
        if self.mode == "setup":
            if len(pwd) < 8:
                self.status.config(text="Password must be at least 8 characters."); return
            if pwd != self.confirm_var.get():
                self.status.config(text="Passwords do not match."); return
            self.vault.setup(pwd)
            messagebox.showinfo("Vault Created", "Your vault has been created successfully!", parent=self)
        else:
            if not self.vault.unlock(pwd):
                self.status.config(text="Incorrect master password. Try again."); return
        self.destroy()
        self.on_success()


