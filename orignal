class EnixApp(tk.Tk):
    def __init__(self):
        super().__init__()
        self.vault = Vault()
        self.withdraw()  # hide until login
        self.title(APP_NAME)
        self.configure(bg=C["bg"])
        self.minsize(900, 600)
        self._center(1060, 680)
        # Set window icon — ICO embedded for Windows taskbar/titlebar
        try:
            import base64 as _b64, tempfile as _tmp, os as _os2
            _ico_data = _b64.b64decode(_ICO_B64)
            _ico_path = _os2.path.join(_tmp.gettempdir(), "enix_app.ico")
            with open(_ico_path, "wb") as _f:
                _f.write(_ico_data)
            self.iconbitmap(default=_ico_path)
        except Exception:
            try:
                from PIL import Image as _Img, ImageTk as _ITk
                import io as _io, base64 as _b64
                _img = _Img.open(_io.BytesIO(_b64.b64decode(_ICON_B64)))
                self._app_icon = _ITk.PhotoImage(_img)
                self.iconphoto(True, self._app_icon)
            except Exception:
                pass
        self._build_ui()
        self._start()

    def _center(self, w, h):
        sw = self.winfo_screenwidth()
        sh = self.winfo_screenheight()
        self.geometry(f"{w}x{h}+{(sw-w)//2}+{(sh-h)//2}")

    # ─── build skeleton UI (shown after unlock) ──
