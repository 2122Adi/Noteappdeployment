        self.canvas = tk.Canvas(list_frame, bg=C["bg"],
                                highlightthickness=0, bd=0)
        self.scrollbar = tk.Scrollbar(list_frame, orient="vertical",
                                      command=self.canvas.yview)
        self.canvas.configure(yscrollcommand=self.scrollbar.set)
        self.scrollbar.pack(side="right", fill="y")
        self.canvas.pack(fill="both", expand=True)
        self.list_inner = tk.Frame(self.canvas, bg=C["bg"])
        self._list_win  = self.canvas.create_window((0,0), window=self.list_inner, anchor="nw")
        self.list_inner.bind("<Configure>", self._on_list_configure)
        self.canvas.bind("<Configure>", self._on_canvas_configure)
        self.canvas.bind_all("<MouseWheel>", self._on_mousewheel)

        # Detail panel
        self.detail_frame = tk.Frame(pane, bg=C["surface"])
        pane.add(self.detail_frame, minsize=320)
        self._show_empty_detail()

    def _build_statusbar(self):
        sb = tk.Frame(self, bg=C["surface"], height=26)
        sb.pack(side="bottom", fill="x")
        sb.pack_propagate(False)
        self.status_lbl = tk.Label(sb, text=f"  {APP_NAME} v{VERSION}  |  Developed by {DEVELOPER}  |  {WEBSITE}",
                                   font=FONT_SMALL, fg=C["text3"], bg=C["surface"], anchor="w")
        self.status_lbl.pack(side="left")
        self.lock_icon = tk.Label(sb, text="🔒 Encrypted", font=FONT_SMALL,
                                  fg=C["success"], bg=C["surface"])
        self.lock_icon.pack(side="right", padx=12)

    # ─── startup flow ─────────────────────────
    def _start(self):
        self.after(100, self._do_start)

    def _do_start(self):
        if not self.vault.is_configured():
            MasterScreen(self.vault, self._on_unlocked, mode="setup")
        else:
            MasterScreen(self.vault, self._on_unlocked, mode="unlock")

    def _on_unlocked(self):
        self.deiconify()
        self.refresh()

    def _lock(self):
        self.vault.lock()
        self.withdraw()
        self._do_start()

    # ─── list rendering ───────────────────────
    def refresh(self, query="", category="all"):
        if query:
            items = self.vault.search(query)
        else:
            items = self.vault.entries

        if category != "all":
            items = [e for e in items if e.get("category") == category]

        for w in self.list_inner.winfo_children():
            w.destroy()

        if not items:
            empty = tk.Frame(self.list_inner, bg=C["bg"])
            empty.pack(fill="x", padx=20, pady=40)
            tk.Label(empty, text="🔍", font=("Segoe UI", 32), bg=C["bg"]).pack()
            tk.Label(empty, text="No entries found", font=FONT_HEAD,
                     fg=C["text2"], bg=C["bg"]).pack(pady=4)
            tk.Label(empty, text='Click "Add Password" to get started.',
                     font=FONT_LABEL, fg=C["text3"], bg=C["bg"]).pack()
        else:
            for entry in items:
                self._entry_card(entry)

        total = len(self.vault.entries)
        self.count_label.config(text=f"{total} item{'s' if total != 1 else ''}")
        self.topbar_count.config(text=f"  ({len(items)} shown)")

    def _entry_card(self, entry: dict):
        cat_icons = {"Login":"🔑","Email":"📧","Banking":"🏦","Social":"💬",
                     "Work":"💼","Shopping":"🛒","API Key":"🔧","Note":"📝","Other":"📁"}
        icon = cat_icons.get(entry.get("category",""), "🔑")

        card = tk.Frame(self.list_inner, bg=C["surface"],
                        highlightthickness=1, highlightbackground=C["border"])
        card.pack(fill="x", padx=12, pady=4)

        inner = tk.Frame(card, bg=C["surface"])
        inner.pack(fill="x", padx=12, pady=10)

        left = tk.Frame(inner, bg=C["surface"])
        left.pack(side="left", fill="x", expand=True)
        tk.Label(left, text=f"{icon}  {entry.get('title','Untitled')}",
                 font=("Segoe UI", 11, "bold"),
                 fg=C["text"], bg=C["surface"], anchor="w").pack(fill="x")
        tk.Label(left, text=entry.get("username","—"),
                 font=FONT_SMALL, fg=C["text2"], bg=C["surface"], anchor="w").pack(fill="x")

        right = tk.Frame(inner, bg=C["surface"])
        right.pack(side="right")
        tk.Label(right, text=entry.get("category",""),
                 font=("Segoe UI", 8), fg=C["accent2"],
                 bg=C["surface2"], padx=6, pady=2).pack()

        # hover + click
        for w in [card, inner, left, right]:
            w.bind("<Enter>", lambda e, c=card: c.config(bg=C["surface2"],
                    highlightbackground=C["accent"]))
            w.bind("<Leave>", lambda e, c=card: c.config(bg=C["surface"],
                    highlightbackground=C["border"]))
            w.bind("<Button-1>", lambda e, eid=entry["id"]: self._show_detail(eid))

    # ─── detail panel ─────────────────────────
    def _show_empty_detail(self):
        for w in self.detail_frame.winfo_children():
            w.destroy()
        f = tk.Frame(self.detail_frame, bg=C["surface"])
        f.place(relx=0.5, rely=0.5, anchor="center")
        tk.Label(f, text="🔐", font=("Segoe UI", 40), bg=C["surface"]).pack()
        tk.Label(f, text="Select an entry to view details",
                 font=FONT_LABEL, fg=C["text3"], bg=C["surface"]).pack(pady=6)

    def _show_detail(self, eid: str):
        entry = next((e for e in self.vault.entries if e["id"] == eid), None)
        if not entry: return

        for w in self.detail_frame.winfo_children():
            w.destroy()

        cat_icons = {"Login":"🔑","Email":"📧","Banking":"🏦","Social":"💬",
                     "Work":"💼","Shopping":"🛒","API Key":"🔧","Note":"📝","Other":"📁"}
        icon = cat_icons.get(entry.get("category",""), "🔑")

        # Header
        hdr = tk.Frame(self.detail_frame, bg=C["surface2"], height=80)
        hdr.pack(fill="x")
        hdr.pack_propagate(False)
        tk.Label(hdr, text=f"{icon}  {entry.get('title','Untitled')}",
                 font=FONT_HEAD, fg=C["text"], bg=C["surface2"]).place(x=16, y=16)
        cat_lbl = entry.get("category","")
        tk.Label(hdr, text=f"  {cat_lbl}  ",
                 font=FONT_SMALL, fg=C["accent2"],
                 bg=C["surface"]).place(x=16, y=48)

        body = tk.Frame(self.detail_frame, bg=C["surface"])
        body.pack(fill="both", expand=True, padx=20, pady=16)

        def detail_row(title, value, is_secret=False):
            rf = tk.Frame(body, bg=C["surface"])
            rf.pack(fill="x", pady=6)
            tk.Label(rf, text=title, font=FONT_SMALL, fg=C["text2"],
                     bg=C["surface"], anchor="w").pack(fill="x")
            row = tk.Frame(rf, bg=C["surface"])
            row.pack(fill="x")
            var = tk.StringVar(value="•" * len(value) if is_secret else value)
            lbl = tk.Label(row, textvariable=var, font=FONT_MONO if is_secret else FONT_LABEL,
                           fg=C["text"] if not is_secret else C["warning"],
                           bg=C["surface2"], anchor="w", padx=10, pady=6)
            lbl.pack(side="left", fill="x", expand=True)
            shown = [False]
            def copy_val():
                self.clipboard_clear(); self.clipboard_append(value)
                self._flash_status(f"📋 {title} copied!")
            tk.Button(row, text="📋", font=("Segoe UI", 10), bg=C["surface2"],
                      fg=C["text2"], relief="flat", bd=0, cursor="hand2",
                      command=copy_val).pack(side="right", padx=4)
            if is_secret:
                def toggle_show():
                    shown[0] = not shown[0]
                    var.set(value if shown[0] else "•" * len(value))
                    lbl.config(fg=C["text"] if shown[0] else C["warning"])
                tk.Button(row, text="👁", font=("Segoe UI", 10), bg=C["surface2"],
                          fg=C["text2"], relief="flat", bd=0, cursor="hand2",
                          command=toggle_show).pack(side="right", padx=2)

        detail_row("USERNAME / EMAIL", entry.get("username","—"))
        detail_row("PASSWORD", entry.get("password","—"), is_secret=True)
        if entry.get("url"):
            detail_row("WEBSITE URL", entry.get("url"))
        if entry.get("notes"):
            detail_row("NOTES", entry.get("notes"))

        # Strength
        tk.Frame(body, bg=C["border"], height=1).pack(fill="x", pady=8)
        tk.Label(body, text="Password Strength", font=FONT_SMALL,
                 fg=C["text2"], bg=C["surface"], anchor="w").pack(fill="x")
        sb = StrengthBar(body)
        sb.pack(anchor="w", pady=4)
        sb.update_strength(entry.get("password",""))

        # Dates
        tk.Frame(body, bg=C["border"], height=1).pack(fill="x", pady=8)
        created = entry.get("created","")[:10]
        updated = entry.get("updated","")[:10]
        tk.Label(body, text=f"Created: {created}   Last updated: {updated}",
                 font=FONT_SMALL, fg=C["text3"], bg=C["surface"]).pack(anchor="w")

        # Action buttons
        btn_f = tk.Frame(self.detail_frame, bg=C["surface"])
        btn_f.pack(fill="x", padx=20, pady=12, side="bottom")
        IconButton(btn_f, "🗑 Delete", style="danger",
                   command=lambda: self._delete_entry(eid)).pack(side="right", padx=6)
        IconButton(btn_f, "✏️ Edit", style="ghost",
                   command=lambda: self._edit_entry(eid)).pack(side="right")

    # ─── CRUD actions ─────────────────────────
    def _add_entry(self):
        EntryDialog(self, self.vault, on_save=self.refresh)

    def _edit_entry(self, eid: str):
        entry = next((e for e in self.vault.entries if e["id"] == eid), None)
        if entry:
            EntryDialog(self, self.vault, entry=entry, on_save=lambda: (self.refresh(), self._show_detail(eid)))

    def _delete_entry(self, eid: str):
        if messagebox.askyesno("Delete Entry",
                               "Are you sure you want to delete this entry?\nThis action cannot be undone.",
                               parent=self):
            self.vault.delete(eid)
            self._show_empty_detail()
            self.refresh(category=self._active_cat)
            self._flash_status("🗑 Entry deleted.")

    # ─── search / filter ──────────────────────
    def _on_search(self, *_):
        q = self.search_var.get()
        self.refresh(query=q, category=self._active_cat)

    def _filter_cat(self, cat: str):
        self._active_cat = cat
        for k, b in self.cat_buttons.items():
            if k == cat:
                b.config(bg=C["surface2"], fg=C["accent"],
                         font=("Segoe UI", 10, "bold"))
            else:
                b.config(bg=C["surface"], fg=C["text2"],
                         font=FONT_LABEL)
        names = {"all":"All Passwords","Login":"Logins","Email":"Emails",
                 "Banking":"Banking","Social":"Social","Work":"Work",
                 "Shopping":"Shopping","API Key":"API Keys","Note":"Notes","Other":"Other"}
        if hasattr(self, "topbar_title"):
            self.topbar_title.config(text=names.get(cat, cat))
        if hasattr(self, "list_inner"):
            self.refresh(query=self.search_var.get(), category=cat)

    # ─── canvas scroll helpers ─────────────────
    def _on_list_configure(self, e):
        self.canvas.configure(scrollregion=self.canvas.bbox("all"))

    def _on_canvas_configure(self, e):
        self.canvas.itemconfig(self._list_win, width=e.width)

    def _on_mousewheel(self, e):
        self.canvas.yview_scroll(int(-1*(e.delta/120)), "units")

    # ─── status flash ─────────────────────────
    def _flash_status(self, msg: str):
        self.status_lbl.config(text=f"  {msg}", fg=C["success"])
        self.after(3000, lambda: self.status_lbl.config(
            text=f"  {APP_NAME} v{VERSION}  |  Developed by {DEVELOPER}  |  {WEBSITE}",
            fg=C["text3"]))


